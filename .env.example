# Sample .env.local configuration
# Copy this file to .env.local and fill in your values

# ===========================================
# REQUIRED
# ===========================================

# Google Gemini API Key (required)
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# OPTIONAL - Model Configuration
# ===========================================

# Gemini model to use (default: gemini-2.5-flash)
# Options: gemini-2.5-flash, gemini-2.5-pro, gemini-3-pro-preview
GEMINI_MODEL=gemini-2.5-flash

# Maximum output tokens (default: 65536)
GEMINI_MAX_OUTPUT_TOKENS=65536

# Temperature (default: 0.4)
GEMINI_TEMPERATURE=0.4

# ===========================================
# OPTIONAL - Tools
# ===========================================

# Enable Google Search Grounding (recommended)
ENABLE_GEMINI_GOOGLE_SEARCH=true

# Enable Code Execution (experimental)
ENABLE_GEMINI_CODE_EXECUTION=false

# Enable Function Calling
ENABLE_GEMINI_FUNCTIONS=false

# Enable URL Context
ENABLE_URL_CONTEXT=true

# ===========================================
# OPTIONAL - Exa Search (Alternative Search)
# ===========================================

# Use Exa as primary search provider instead of Google
# Get your key at: https://exa.ai
ENABLE_EXA_PRIMARY=false
EXA_API_KEY=your_exa_api_key_here

# ===========================================
# OPTIONAL - Performance
# ===========================================

# Concurrency limit for API calls (default: 5)
CONCURRENCY_LIMIT=5

# Provider cache TTL in milliseconds (default: 600000 = 10 minutes)
PROVIDER_CACHE_TTL_MS=600000

# ===========================================
# OPTIONAL - Logging
# ===========================================

# Log level: debug, info, warn, error (default: warn)
LOG_LEVEL=warn